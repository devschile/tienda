# API Configuration
VITE_API_URL=https://api.example.com/v1

# NeonDB (Postgres serverless) - solo para Netlify Functions, NUNCA con prefijo VITE_
# Obtén el connection string en https://console.neon.tech (formato: postgresql://user:password@host/dbname?sslmode=require)
NEON_DATABASE_URL=postgresql://user:password@ep-example-12345.us-east-2.aws.neon.tech/tienda?sslmode=require

# MercadoPago Configuration
VITE_MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key_here
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token_here

# Netlify Functions Environment
ALLOWED_ORIGINS=https://your-domain.netlify.app,http://localhost:3000
SITE_URL=http://localhost:3000
