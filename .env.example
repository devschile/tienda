# API Configuration
VITE_API_URL=https://api.example.com/v1

# NeonDB (Postgres serverless) - solo para Netlify Functions, NUNCA con prefijo VITE_
NEON_DATABASE_URL=postgresql://user:password@ep-example.aws.neon.tech/neondb?sslmode=require

# MercadoPago Configuration
VITE_MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key_here
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token_here

# Webhook secret (configurar en panel de MercadoPago → Tu aplicación → Webhooks)
MERCADOPAGO_WEBHOOK_SECRET=tu_webhook_secret_aqui

# Email (Resend para testing, Mailgun para producción)
EMAIL_PROVIDER=resend            # resend | mailgun
RESEND_API_KEY=re_xxxx           # si EMAIL_PROVIDER=resend
FROM_EMAIL=tienda@andalaosa.cl   # dominio verificado en Resend (testing) o Mailgun (prod)

# Mailgun (solo producción)
MAILGUN_API_KEY=key-xxxx
MAILGUN_DOMAIN=mg.tienda.devschile.cl
MAILGUN_URL=https://api.mailgun.net   # o https://api.eu.mailgun.net si Europa

# Admin Panel (JWT sin dependencias externas)
ADMIN_EMAIL=admin@devschile.cl
ADMIN_PASSWORD=contraseña-segura-aqui
ADMIN_JWT_SECRET=string-aleatorio-64-chars-aqui
ALLOWED_ORIGINS=https://tienda.devschile.cl,https://tienda-devschile.netlify.app,http://localhost:3000
SITE_URL=http://localhost:3000
NODE_ENV=production

# Uploadthing - image upload
UPLOADTHING_TOKEN=tu_token_aqui    # dashboard.uploadthing.com → API Keys
